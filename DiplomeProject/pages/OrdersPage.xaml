<Page x:Class="KitchenManager.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KitchenManager.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Заказы" Loaded="Page_Loaded" Background="{StaticResource AppBackground}">

    <Page.Resources>
        <local:GroupTotalConverter x:Key="GroupTotalConverter"/>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Заказы" FontSize="36" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,30,0"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Поиск:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,15,0" FontSize="18" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtSearch" Width="350" Height="45" FontSize="18" VerticalContentAlignment="Center" TextChanged="TxtSearch_TextChanged"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="+ Новый заказ" Width="180" Height="50" FontSize="16" Margin="0,0,10,0" Click="BtnAdd_Click" Style="{StaticResource SuccessBtnStyle}"/>
                <Button Content="Изменить" Width="130" Height="50" FontSize="16" Margin="0,0,10,0" Click="BtnEdit_Click" Style="{StaticResource PrimaryBtnStyle}"/>
                <Button Content="Удалить" Width="110" Height="50" FontSize="16" Click="BtnDelete_Click" Style="{StaticResource DangerBtnStyle}"/>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,25" Height="120">
            <Border Background="#6C5CE7" CornerRadius="12" Padding="20" Margin="0,0,10,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ВСЕГО ПОЗИЦИЙ" FontSize="14" Foreground="#E0DFFF" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtTotalOrdersCount" Text="0" FontSize="36" Foreground="White" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#00B894" CornerRadius="12" Padding="20" Margin="10,0,10,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ОБЩАЯ ВЫРУЧКА" FontSize="14" Foreground="#D1F7ED" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtTotalRevenue" Text="0 ₽" FontSize="36" Foreground="White" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#FDCB6E" CornerRadius="12" Padding="20" Margin="10,0,0,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ЗАКАЗОВ В РАБОТЕ" FontSize="14" Foreground="#FFF4DB" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtActiveOrdersCount" Text="0" FontSize="36" Foreground="White" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,170,0,10" Panel.ZIndex="10">
            <Button x:Name="BtnPrint" Content="🖨 Печать заказа" Click="BtnPrint_Click" Style="{StaticResource SuccessBtnStyle}" Width="180" Height="45" FontSize="15" Margin="0,0,10,0"/>
            <Button x:Name="BtnWord" Content="📝 Договор (Word)" Click="BtnWord_Click" Background="#2B579A" Foreground="White" Width="180" Height="45" FontSize="15" Margin="0,0,10,0"/>
            <Button x:Name="BtnExport" Content="📊 В Excel" Click="BtnExport_Click" Background="#207347" Foreground="White" Width="130" Height="45" FontSize="15"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource CardBackground}" CornerRadius="15" Effect="{StaticResource CardShadow}" Margin="0,50,0,0">
            <DataGrid x:Name="DGridOrders" AutoGenerateColumns="False" IsReadOnly="True" Margin="15" BorderThickness="0" FontSize="18" RowHeight="60">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontSize" Value="16"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Height" Value="50"/>
                        <Setter Property="Padding" Value="10,0"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <Expander IsExpanded="True" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,15">
                                                <Expander.Header>
                                                    <StackPanel Orientation="Horizontal" Margin="10">
                                                        <Border Background="{Binding Items[0].StatusColor}" CornerRadius="6" Padding="12,4" Margin="0,0,15,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Items[0].OrderStatus.StatusName}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                                        </Border>

                                                        <TextBlock Text="📦 ОБЩИЙ ЗАКАЗ ОТ " FontWeight="Bold" Foreground="#4A5568" FontSize="18" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name, StringFormat='dd.MM.yyyy HH:mm'}" FontWeight="Bold" Foreground="#6C5CE7" FontSize="18" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" — Позиций: " Foreground="Gray" FontSize="18" Margin="25,0,0,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding ItemCount}" FontWeight="Bold" Foreground="#00B894" FontSize="18" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" — Общая стоимость: " Foreground="Gray" FontSize="18" Margin="25,0,0,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Items, Converter={StaticResource GroupTotalConverter}}" FontWeight="Bold" Foreground="#D63031" FontSize="18" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Expander.Header>
                                                <ItemsPresenter />
                                            </Expander>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </DataGrid.GroupStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID_Order}" Width="70"/>

                    <DataGridTextColumn Header="КЛИЕНТ" Binding="{Binding ClientFullName}" Width="2*"/>

                    <DataGridTemplateColumn Header="ТОВАР / УСЛУГА" Width="3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Equipment.Title}" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Services.Title}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="СУММА" Binding="{Binding TotalPrice, StringFormat='{}{0:N0} ₽'}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="20"/>
                                <Setter Property="Foreground" Value="#2D3436"/>
                                <Setter Property="Margin" Value="10,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>