<Page x:Class="KitchenManager.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      MinHeight="300" MinWidth="550"
      Title="Авторизация" Background="{StaticResource AppBackground}">

    <Grid>
        <Border Background="{StaticResource CardBackground}" CornerRadius="15" Width="360" Height="420" Effect="{StaticResource CardShadow}" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Margin="30">
                
                <Image Source="/Resources/unnamed.png" Width="300" Height="150"/>

              

                <TextBlock Text="Логин" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtLogin" Height="38" Margin="0,0,0,20"/>

                <TextBlock Text="Пароль" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                <PasswordBox x:Name="TxtPassword" Height="38" Margin="0,0,0,35" Padding="10,8" BorderBrush="#E2E8F0" BorderThickness="1" Background="#F7FAFC"/>

                <Button Content="Войти" Click="BtnLogin_Click" Height="30" Style="{StaticResource PrimaryBtnStyle}" FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>