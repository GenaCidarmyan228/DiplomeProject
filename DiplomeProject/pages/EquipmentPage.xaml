<Page x:Class="KitchenManager.Pages.EquipmentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Склад оборудования" Loaded="Page_Loaded" Background="{StaticResource AppBackground}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Оборудование" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,20,0"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Поиск:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtSearch" Width="250" Height="35" TextChanged="TxtSearch_TextChanged"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="+ Добавить товар" Width="160" Margin="0,0,10,0" Click="BtnAdd_Click" Style="{StaticResource SuccessBtnStyle}"/>
                <Button Content="Изменить" Width="110" Margin="0,0,10,0" Click="BtnEdit_Click" Style="{StaticResource PrimaryBtnStyle}"/>
                <Button Content="Удалить" Width="100" Click="BtnDelete_Click" Style="{StaticResource DangerBtnStyle}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource CardBackground}" CornerRadius="10" Effect="{StaticResource CardShadow}">
            <DataGrid x:Name="DGridEquipment" AutoGenerateColumns="False" IsReadOnly="True" Margin="15" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="НАЗВАНИЕ" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="ОПИСАНИЕ" Binding="{Binding Description}" Width="2*"/>
                    <DataGridTextColumn Header="ЦЕНА" Binding="{Binding Price, StringFormat='{}{0:N2} ₽'}" Width="120"/>
                    <DataGridTextColumn Header="ОСТАТОК (ШТ.)" Binding="{Binding StockQuantity}" Width="130" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>