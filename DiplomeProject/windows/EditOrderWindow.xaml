<Window x:Class="KitchenManager.Windows.EditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование заказа" Height="650" Width="650"
        Icon="/resources/unnamed.png" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource AppBackground}"
        Loaded="Window_Loaded">

    <Border Background="{StaticResource CardBackground}" CornerRadius="10" Margin="20" Padding="30" Effect="{StaticResource CardShadow}">
        <StackPanel>
            <TextBlock Text="Редактирование заказа" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Статус:" FontSize="18" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,20"/>
                <ComboBox x:Name="ComboStatus" Grid.Row="0" Grid.Column="1" DisplayMemberPath="StatusName" SelectedValuePath="ID_Status" FontSize="18" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,20" Padding="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Клиент:" FontSize="18" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,20"/>
                <ComboBox x:Name="ComboClients" Grid.Row="1" Grid.Column="1" DisplayMemberPath="FullName" SelectedValuePath="ID_Client" FontSize="18" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,20" Padding="5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Оборудование:" FontSize="18" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,20"/>
                <ComboBox x:Name="ComboEquipment" Grid.Row="2" Grid.Column="1" DisplayMemberPath="Title" SelectedValuePath="ID_Equipment" FontSize="18" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,20" Padding="5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Услуга:" FontSize="18" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,20"/>
                <ComboBox x:Name="ComboServices" Grid.Row="3" Grid.Column="1" DisplayMemberPath="Title" SelectedValuePath="ID_Service" FontSize="18" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,20" Padding="5"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Сотрудник:" FontSize="18" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,30"/>
                <ComboBox x:Name="ComboEmployees" Grid.Row="4" Grid.Column="1" DisplayMemberPath="FullName" SelectedValuePath="ID_Employee" FontSize="18" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,30" Padding="5"/>
            </Grid>

            <Button Content="Сохранить изменения" Click="BtnSave_Click" Height="55" FontSize="20" FontWeight="Bold" Style="{StaticResource SuccessBtnStyle}"/>
        </StackPanel>
    </Border>
</Window>