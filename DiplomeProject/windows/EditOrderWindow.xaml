<Window x:Class="KitchenManager.Windows.EditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование заказа" Height="550" Width="430"
        Icon="/resources/unnamed.png" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource AppBackground}"
        Loaded="Window_Loaded">

    <Border Background="{StaticResource CardBackground}" CornerRadius="10" Margin="20" Padding="25" Effect="{StaticResource CardShadow}">
        <StackPanel>
            <TextBlock Text="Редактирование заказа" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Статус:" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,15"/>
                <ComboBox x:Name="ComboStatus" Grid.Row="0" Grid.Column="1" DisplayMemberPath="StatusName" SelectedValuePath="ID_Status" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Клиент:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,15"/>
                <ComboBox x:Name="ComboClients" Grid.Row="1" Grid.Column="1" DisplayMemberPath="FullName" SelectedValuePath="ID_Client" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Оборудование:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,15"/>
                <ComboBox x:Name="ComboEquipment" Grid.Row="2" Grid.Column="1" DisplayMemberPath="Title" SelectedValuePath="ID_Equipment" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Услуга:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,15"/>
                <ComboBox x:Name="ComboServices" Grid.Row="3" Grid.Column="1" DisplayMemberPath="Title" SelectedValuePath="ID_Service" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Сотрудник:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,25"/>
                <ComboBox x:Name="ComboEmployees" Grid.Row="4" Grid.Column="1" DisplayMemberPath="FullName" SelectedValuePath="ID_Employee" Margin="0,0,0,25" Padding="5"/>
            </Grid>

            <Button Content="Сохранить изменения" Click="BtnSave_Click" Style="{StaticResource SuccessBtnStyle}"/>
        </StackPanel>
    </Border>
</Window>