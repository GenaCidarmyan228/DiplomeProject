<Window x:Class="KitchenManager.Windows.AddServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая услуга" Height="340" Width="330"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource AppBackground}">

    <Border Background="{StaticResource CardBackground}" CornerRadius="10" Margin="20" Padding="25" Effect="{StaticResource CardShadow}">
        <StackPanel>
            <TextBlock Text="Добавление услуги" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Название услуги:" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtTitle" Margin="0,0,0,12"/>

            <TextBlock Text="Стоимость (руб):" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtPrice" Margin="0,0,0,25"/>

            <Button Content="Сохранить" Click="BtnSave_Click" Style="{StaticResource SuccessBtnStyle}"/>
        </StackPanel>
    </Border>
</Window>