<Window x:Class="KitchenManager.AddClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый клиент" Height="750" Width="500"
        Icon="/resources/unnamed.png" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource AppBackground}">

    <Border Background="{StaticResource CardBackground}" CornerRadius="10" Margin="20" Padding="30" Effect="{StaticResource CardShadow}">
        <StackPanel>
            <TextBlock Text="Новый клиент" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <TextBlock Text="Фамилия" FontSize="18" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Surname}" FontSize="18" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Имя" FontSize="18" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Name}" FontSize="18" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Отчество" FontSize="18" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Patronymic}" FontSize="18" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Телефон" FontSize="18" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <TextBox x:Name="TxtPhone" Text="{Binding Phone}" FontSize="18" Height="40" VerticalContentAlignment="Center"
                         TextChanged="TxtPhone_TextChanged" 
                         PreviewTextInput="TxtPhone_PreviewTextInput"/>

                <TextBlock x:Name="HintPhone" Text="+7 (___) ___-__-__" 
                           FontSize="18" Foreground="#A0AEC0" VerticalAlignment="Center" 
                           Margin="12,0,0,0" IsHitTestVisible="False"/>
            </Grid>

            <TextBlock Text="Адрес" FontSize="18" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Address}" FontSize="18" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,30"/>

            <Button Content="Сохранить" Click="BtnSave_Click" Height="55" FontSize="20" FontWeight="Bold" Style="{StaticResource SuccessBtnStyle}" Cursor="Hand"/>
        </StackPanel>
    </Border>
</Window>