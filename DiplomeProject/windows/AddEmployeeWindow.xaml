<Window x:Class="KitchenManager.AddEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый сотрудник" Height="550" Width="360"
        Icon="/resources/unnamed.png" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource AppBackground}">

    <Border Background="{StaticResource CardBackground}" CornerRadius="10" Margin="20" Padding="25" Effect="{StaticResource CardShadow}">
        <StackPanel>
            <TextBlock Text="Сотрудник" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Фамилия" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Surname}" Margin="0,0,0,12"/>

            <TextBlock Text="Имя" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Name}" Margin="0,0,0,12"/>

            <TextBlock Text="Отчество" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Patronymic}" Margin="0,0,0,12"/>

            <TextBlock Text="Должность" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <ComboBox x:Name="ComboPosition" DisplayMemberPath="PositionName" SelectedValuePath="ID_Position" SelectedValue="{Binding ID_Position}" Margin="0,0,0,12" Padding="5"/>

            <TextBlock Text="Телефон" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,25">
                <TextBox x:Name="TxtPhone" Text="{Binding Phone}" 
                         TextChanged="TxtPhone_TextChanged" 
                         PreviewTextInput="TxtPhone_PreviewTextInput"/>

                <TextBlock x:Name="HintPhone" Text="+7 (___) ___-__-__" 
                           Foreground="#A0AEC0" VerticalAlignment="Center" 
                           Margin="12,0,0,0" IsHitTestVisible="False"/>
            </Grid>

            <Button Content="Сохранить" Click="BtnSave_Click" Style="{StaticResource SuccessBtnStyle}"/>
        </StackPanel>
    </Border>
</Window>