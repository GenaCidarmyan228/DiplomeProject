<Window x:Class="KitchenManager.Windows.AddPositionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая должность" Height="400" Width="450"
        Icon="/resources/unnamed.png" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource AppBackground}">

    <Border Background="{StaticResource CardBackground}" CornerRadius="10" Margin="20" Padding="30" Effect="{StaticResource CardShadow}">
        <StackPanel>
            <TextBlock Text="Добавление должности" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="Название должности:" FontSize="18" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"/>
            <TextBox x:Name="TxtName" FontSize="18" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,30"/>

            <Button Content="Добавить" Click="BtnAdd_Click" Height="55" FontSize="20" FontWeight="Bold" Style="{StaticResource SuccessBtnStyle}"/>
        </StackPanel>
    </Border>
</Window>