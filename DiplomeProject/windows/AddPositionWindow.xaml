<Window x:Class="KitchenManager.Windows.AddPositionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая должность" Height="300" Width="330"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource AppBackground}">

    <Border Background="{StaticResource CardBackground}" CornerRadius="10" Margin="20" Padding="25" Effect="{StaticResource CardShadow}">
        <StackPanel>
            <TextBlock Text="Добавление должности" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Название должности:" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtName" Margin="0,0,0,25"/>

            <Button Content="Добавить" Click="BtnAdd_Click" Style="{StaticResource SuccessBtnStyle}"/>
        </StackPanel>
    </Border>
</Window>