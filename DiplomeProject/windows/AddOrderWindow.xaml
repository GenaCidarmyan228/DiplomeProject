<Window x:Class="KitchenManager.Windows.AddOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый заказ" Height="600" Width="650"
        Icon="/resources/unnamed.png" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource AppBackground}"
        Loaded="Window_Loaded">

    <Border Background="{StaticResource CardBackground}" CornerRadius="10" Margin="20" Padding="30" Effect="{StaticResource CardShadow}">
        <StackPanel>
            <TextBlock Text="Оформление заказа" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Клиент:" FontSize="18" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,20"/>
                <ComboBox x:Name="ComboClients" Grid.Row="0" Grid.Column="1" SelectedValuePath="ID_Client" FontSize="18" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,20" Padding="5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ID: " Foreground="#A0AEC0" FontSize="18"/>
                                <TextBlock Text="{Binding ID_Client}" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" FontSize="18"/>
                                <TextBlock Text=" — " Foreground="#A0AEC0" FontSize="18"/>
                                <TextBlock Text="{Binding Surname}" FontSize="18"/>
                                <TextBlock Text=" "/>
                                <TextBlock Text="{Binding Name}" FontSize="18"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Товар:" FontSize="18" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,20">
                    <ComboBox x:Name="ComboEquipment" DisplayMemberPath="Title" SelectedValuePath="ID_Equipment" FontSize="18" Height="45" VerticalContentAlignment="Center" Padding="5" SelectionChanged="ComboEquipment_SelectionChanged"/>

                    <StackPanel Margin="0,5,0,0">
                        <TextBlock x:Name="TxtStockInfo" Text="Остаток на складе: выберите товар" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                        <ProgressBar x:Name="PbStock" Height="10" Minimum="0" Maximum="20" Value="0" Background="#E9ECEF" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Услуга:" FontSize="18" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,20"/>
                <ComboBox x:Name="ComboServices" Grid.Row="2" Grid.Column="1" DisplayMemberPath="Title" SelectedValuePath="ID_Service" FontSize="18" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,20" Padding="5"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Сотрудник:" FontSize="18" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,30"/>
                <ComboBox x:Name="ComboEmployees" Grid.Row="3" Grid.Column="1" SelectedValuePath="ID_Employee" FontSize="18" Height="45" VerticalContentAlignment="Center" Margin="0,0,0,30" Padding="5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ID: " Foreground="#A0AEC0" FontSize="18"/>
                                <TextBlock Text="{Binding ID_Employee}" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" FontSize="18"/>
                                <TextBlock Text=" — " Foreground="#A0AEC0" FontSize="18"/>
                                <TextBlock Text="{Binding Surname}" FontSize="18"/>
                                <TextBlock Text=" "/>
                                <TextBlock Text="{Binding Name}" FontSize="18"/>
                                <TextBlock Text=" (" Foreground="{StaticResource PrimaryColor}" FontSize="18"/>
                                <TextBlock Text="{Binding Positions.PositionName}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryColor}" FontSize="18"/>
                                <TextBlock Text=")" Foreground="{StaticResource PrimaryColor}" FontSize="18"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Button x:Name="BtnAdd" Content="Оформить заказ" Click="BtnSave_Click" Height="55" FontSize="20" FontWeight="Bold" Style="{StaticResource SuccessBtnStyle}"/>
        </StackPanel>
    </Border>
</Window>