<Window x:Class="KitchenManager.Windows.AddOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый заказ" Height="480" Width="430"
        Icon="/resources/unnamed.png" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource AppBackground}"
        Loaded="Window_Loaded">

    <Border Background="{StaticResource CardBackground}" CornerRadius="10" Margin="20" Padding="25" Effect="{StaticResource CardShadow}">
        <StackPanel>
            <TextBlock Text="Оформление заказа" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Клиент:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,15"/>
                <ComboBox x:Name="ComboClients" Grid.Row="0" Grid.Column="1" SelectedValuePath="ID_Client" Margin="0,0,0,15" Padding="5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ID: " Foreground="#A0AEC0"/>
                                <TextBlock Text="{Binding ID_Client}" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                                <TextBlock Text=" — " Foreground="#A0AEC0"/>
                                <TextBlock Text="{Binding Surname}"/>
                                <TextBlock Text=" "/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Товар:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,15"/>
                <ComboBox x:Name="ComboEquipment" Grid.Row="1" Grid.Column="1" DisplayMemberPath="Title" SelectedValuePath="ID_Equipment" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Услуга:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,15"/>
                <ComboBox x:Name="ComboServices" Grid.Row="2" Grid.Column="1" DisplayMemberPath="Title" SelectedValuePath="ID_Service" Margin="0,0,0,15" Padding="5"/>


                <TextBlock Grid.Row="3" Grid.Column="0" Text="Сотрудник:" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,25"/>
                <ComboBox x:Name="ComboEmployees" Grid.Row="3" Grid.Column="1" SelectedValuePath="ID_Employee" Margin="0,0,0,25" Padding="5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ID: " Foreground="#A0AEC0"/>
                                <TextBlock Text="{Binding ID_Employee}" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
                                <TextBlock Text=" — " Foreground="#A0AEC0"/>
                                <TextBlock Text="{Binding Surname}"/>
                                <TextBlock Text=" "/>
                                <TextBlock Text="{Binding Name}"/>
                                
                                <TextBlock Text=" (" Foreground="{StaticResource PrimaryColor}"/>
                                <TextBlock Text="{Binding Positions.PositionName}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryColor}"/>
                                <TextBlock Text=")" Foreground="{StaticResource PrimaryColor}"/>
                           
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Button x:Name="BtnAdd" Content="Оформить заказ" Click="BtnSave_Click" Style="{StaticResource SuccessBtnStyle}"/>
        </StackPanel>
    </Border>
</Window>