<Window x:Class="KitchenManager.Windows.AddEquipmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="650" Width="500"
        Icon="/resources/unnamed.png" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource AppBackground}">

    <Border Background="{StaticResource CardBackground}" CornerRadius="10" Margin="20" Padding="30" Effect="{StaticResource CardShadow}">
        <StackPanel>
            <TextBlock Text="Данные о товаре" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <TextBlock Text="Название:" FontSize="18" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Title}" FontSize="18" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Описание:" FontSize="18" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Description}" FontSize="18" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Цена (руб):" FontSize="18" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Price}" FontSize="18" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,15"/>

            <TextBlock Text="Количество на складе (шт):" FontSize="18" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
            <TextBox Text="{Binding StockQuantity}" FontSize="18" Height="40" VerticalContentAlignment="Center" Margin="0,0,0,30"/>

            <Button Content="Сохранить" Click="BtnSave_Click" Height="55" FontSize="20" FontWeight="Bold" Style="{StaticResource SuccessBtnStyle}"/>
        </StackPanel>
    </Border>
</Window>