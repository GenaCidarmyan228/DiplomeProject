<Window x:Class="DiplomeProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DiplomeProject"
        mc:Ignorable="d"
         Title="KitchenManager" Height="950" Width="1500" MinHeight="800" MinWidth="1500"
        Icon="/resources/unnamed.png" 
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground}">
    
    <Window.Resources>
        <Style TargetType="Button" x:Key="SidebarMenuBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Margin="10,5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="Sidebar" Grid.Column="0" Width="250" 
                Background="#1E293B" 
                Visibility="Collapsed"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,35,20,35">
                    <TextBlock Text="KITCHEN" FontSize="26" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="MANAGER" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <Border Height="2" Width="50" Background="{StaticResource PrimaryColor}" CornerRadius="1"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button Content="Заказы" Click="BtnOrders_Click" Style="{StaticResource SidebarMenuBtn}"/>
                    <Button Content="Оборудование" Click="BtnEquipment_Click" Style="{StaticResource SidebarMenuBtn}"/>
                    <Button Content="Услуги" Click="BtnServices_Click" Style="{StaticResource SidebarMenuBtn}"/>
                    <Button Content="Клиенты" Click="BtnClients_Click" Style="{StaticResource SidebarMenuBtn}"/>

                    <Border Height="1" Background="#334155" Margin="20,15"/>

                    <Button x:Name="BtnEmployees" Content="Сотрудники" Click="BtnEmployees_Click" Style="{StaticResource SidebarMenuBtn}"/>
                </StackPanel>

                <Button Grid.Row="2" Content="Выход из системы" Click="BtnExit_Click" 
                        Margin="20,0,20,30" Height="45" 
                        Style="{StaticResource DangerBtnStyle}"/>
            </Grid>
        </Border>

        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" ContentRendered="MainFrame_ContentRendered"/>

    </Grid>
</Window>